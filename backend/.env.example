# ── Server (Railway) ──────────────────────
PORT=7000

# ── MySQL (TiDB Cloud / Local) ────────────
DB_HOST=your-tidb-cluster-gateway.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username.root
DB_PASSWORD=your_tidb_password
DB_NAME=CURIO
DB_SSL=true

# ── Admin Seed Account ───────────────────
ADMIN_EMAIL=admin@curio.com
ADMIN_PASSWORD=Admin123!
ADMIN_FNAME=System
ADMIN_LNAME=Admin

# 🤖 AI Services (Gemini & Meshy) ─────────
GEMINI_API_KEY=your_gemini_api_key
MESHY_API_KEY=your_meshy_api_key

# ☁️ Cloudinary Media Uploads ──────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=cloudinary://your_cloudinary_api_key:your_cloudinary_api_secret@your_cloudinary_cloud_name
